generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int      @id @default(autoincrement())
  username        String   @unique
  email           String   @unique
  password        String
  displayName     String?
  supportedTeam   String?
  profilePic      String?
  createdAt       DateTime @default(now())
  
  tweets          Tweet[]  @relation("UserTweets")
  
  upvotedTweets   Tweet[]  @relation("Upvotes")
  downvotedTweets Tweet[]  @relation("Downvotes")

  SentMessages Message[] @relation("SentMessages")
}

model Tweet {
  id            Int      @id @default(autoincrement())
  content       String
  sportCategory String?  // <--- BU SATIRI EKLE
  tags          String?  // <--- BU SATIRI EKLE
  authorId      Int
  author        User     @relation("UserTweets", fields: [authorId], references: [id])
  createdAt     DateTime @default(now())

  // OYLAMA İLİŞKİLERİ:
  upvoters      User[]   @relation("Upvotes")
  downvoters    User[]   @relation("Downvotes")
}

model Feedback {
  id        Int      @id @default(autoincrement())
  content   String
  userId    Int?     // Giriş yapan kullanıcıysa ID'sini tutarız
  createdAt DateTime @default(now())
}

model Message {
  id         Int      @id @default(autoincrement())
  content    String
  senderId   Int
  receiverId Int
  createdAt  DateTime @default(now())

  // User tablosu ile ilişkiler
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}